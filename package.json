{
  "name": "learning-growth-dashboard",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\" \"cd backend && uvicorn main:app --host 127.0.0.1 --port 8000\" --kill-others",
    "verify:css": "node scripts/verify-built-css.mjs",
    "verify:boundaries": "node scripts/verify-component-boundaries.mjs",
    "verify:data": "node scripts/verify-local-json-data.mjs"
  },
  "dependencies": {
    "echarts": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "concurrently": "^9.1.0",
    "electron": "^31.7.7",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "^8.0.1"
  }
}
